#%%
import numpy as np
#%% md
Parameters
#%%
n = 128
q = 2 * (n**2) + 1
m = 2 * n
beta = int(np.sqrt(m))
A = np.random.randint(0, q, (m, m))
#%% md
Alice generating her public key
#%%
s_A = np.random.randint(-beta//2, beta//2, m)
p_A = (A @ s_A) % q

#%% md
Bob generating his public key
#%%
s_B = np.random.randint(-beta//2, beta//2, m)
p_B = (s_B @ A) % q
#%% md
Generating the root keys
#%%
from hashlib import sha256
import math

# Alice and Bob compute the same high-entropy value modulo q
shared_secret_alice_val = (p_B @ s_A) % q
shared_secret_bob_val = (s_B @ p_A) % q

# Use a KDF like SHA-256 to derive a secure key from the shared secret.
num_bytes = math.ceil(q.bit_length() / 8)
root_key_alice = sha256(shared_secret_alice_val.to_bytes(num_bytes, 'big')).digest()
root_key_bob = sha256(shared_secret_bob_val.to_bytes(num_bytes, 'big')).digest()
#%%
print(root_key_alice, root_key_bob)

assert root_key_alice == root_key_bob